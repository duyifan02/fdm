new file mode 100644
index 0000000..4f12644
--- /dev/null
+++ b/exts/fdm/fdm/utils/configclass_patch.py
@@ -0,0 +1,101 @@
+from __future__ import annotations
+
+import importlib
+import inspect
+
+configclass_mod = importlib.import_module("isaaclab.utils.configclass")
+
+
+def install_configclass_cycle_guard() -> None:
+    """Patch Isaac Lab config validation to avoid descending into runtime-mutated class objects.
+
+    Isaac Sim mutates some implementation classes referenced by ``*.class_type`` config fields at runtime.
+    When a second environment is constructed in the same process, Isaac Lab's stock ``_validate`` walks those
+    class objects recursively and can enter cycles such as ``RayCaster.meshes -> ... -> runtime.device_map``.
+
+    The guard below keeps validation focused on actual config data:
+    - skip Python classes, modules and bare functions/methods
+    - keep a visited set so repeated/shared objects do not recurse forever
+    """
+
+    validate_fn = configclass_mod._validate
+    if getattr(validate_fn, "_fdm_cycle_guard_installed", False):
+        return
+
+    def _safe_validate(
+        obj: object,
+        prefix: str = "",
+        _visited: set[int] | None = None,
+        _missing_fields: list[str] | None = None,
+    ) -> list[str]:
+        top_level = _visited is None and _missing_fields is None
+        if _visited is None:
+            _visited = set()
+        if _missing_fields is None:
+            _missing_fields = []
+
+        if type(obj).__name__ == "MeshConverterCfg":
+            pass
+        elif type(obj) is type(MISSING):
+            _missing_fields.append(prefix)
+        elif inspect.isclass(obj) or inspect.ismodule(obj) or inspect.isroutine(obj):
+            # ``class_type`` and other callable implementation hooks are not configuration trees.
+            pass
+        elif isinstance(obj, (list, tuple)):
+            obj_id = id(obj)
+            if obj_id not in _visited:
+                _visited.add(obj_id)
+                for index, item in enumerate(obj):
+                    current_path = f"{prefix}[{index}]"
+                    _validate(
+                        item,
+                        prefix=current_path,
+                        _visited=_visited,
+                        _missing_fields=_missing_fields,
+                    )
+        elif isinstance(obj, dict):
+            obj_id = id(obj)
+            if obj_id not in _visited:
+                _visited.add(obj_id)
+                if any(not isinstance(key, str) for key in obj.keys()):
+                    obj_dict = {str(key): value for key, value in obj.items()}
+                else:
+                    obj_dict = obj
+                for key, value in obj_dict.items():
+                    if key.startswith("__"):
+                        continue
+                    current_path = f"{prefix}.{key}" if prefix else key
+                    _validate(
+                        value,
+                        prefix=current_path,
+                        _visited=_visited,
+                        _missing_fields=_missing_fields,
+                    )
+        elif hasattr(obj, "__dict__"):
+            obj_id = id(obj)
+            if obj_id not in _visited:
+                _visited.add(obj_id)
+                for key, value in obj.__dict__.items():
+                    if key.startswith("__"):
+                        continue
+                    current_path = f"{prefix}.{key}" if prefix else key
+                    _validate(
+                        value,
+                        prefix=current_path,
+                        _visited=_visited,
+                        _missing_fields=_missing_fields,
+                    )
+
+        if top_level and _missing_fields:
+            formatted_message = "\n".join(f"  - {field}" for field in _missing_fields)
+            raise TypeError(
+                f"Missing values detected in object {obj.__class__.__name__} for the following"
+                f" fields:\n{formatted_message}\n"
+            )
+        return _missing_fields
+
+    # Mutate the original function object so already-decorated config classes pick up the new behavior.
+    validate_fn.__code__ = _safe_validate.__code__
+    validate_fn.__defaults__ = _safe_validate.__defaults__
+    validate_fn.__kwdefaults__ = _safe_validate.__kwdefaults__
+    validate_fn._fdm_cycle_guard_installed = True
