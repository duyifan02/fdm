+def _config_dict_to_yaml_safe(obj: object) -> object:
+    # 2026-03-26 TensorBoard add_text 使用 yaml.safe_dump；配置树中可能含 slice 等不可 YAML 序列化对象，先递归转为可序列化形式
+    if obj is None or isinstance(obj, (bool, int, float, str)):
+        return obj
+    if isinstance(obj, slice):
+        return repr(obj)
+    if isinstance(obj, dict):
+        return {str(k): _config_dict_to_yaml_safe(v) for k, v in obj.items()}
+    if isinstance(obj, (list, tuple)):
+        return [_config_dict_to_yaml_safe(x) for x in obj]
+    if isinstance(obj, np.ndarray):
+        return obj.tolist() if obj.size <= 4096 else repr(obj)
+    if isinstance(obj, np.generic):
+        return obj.item()
+    return repr(obj)
+
