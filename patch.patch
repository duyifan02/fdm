+from __future__ import annotations
+
+import os
+
+from fdm import FDM_DATA_DIR
+
+
+def _get_log_dir_path(log_root_path: str) -> str:
+    abs_path = os.path.abspath(log_root_path)
+    return abs_path if os.path.basename(abs_path) == "fdm" else os.path.split(abs_path)[0]
+
+
+def get_test_dataset_root(log_root_path: str | None = None) -> str:
+    """Return the repository-local root directory for cached/static test datasets."""
+    if log_root_path is None:
+        return os.path.abspath(os.path.join("logs", "fdm", "test_datasets"))
+    return os.path.join(_get_log_dir_path(log_root_path), "test_datasets")
+
+
+def get_robot_test_dataset_dir(robot: str, log_root_path: str | None = None) -> str:
+    """Return the robot-scoped test dataset directory."""
+    return os.path.join(get_test_dataset_root(log_root_path), robot.lower())
+
+
+def replace_test_dataset_tokens(path_template: str, log_root_path: str, robot: str) -> str:
+    """Expand dataset path templates used by trainer configs."""
+    log_dir_path = _get_log_dir_path(log_root_path)
+    return path_template.replace("{LOG_DIR}", log_dir_path).replace("{ROBOT}", robot.lower())
+
+
+def get_static_test_dataset_path(log_root_path: str | None, robot: str, dataset_filename: str) -> str:
+    """Return the canonical robot-scoped path for a static test dataset pickle."""
+    return os.path.join(get_robot_test_dataset_dir(robot, log_root_path), dataset_filename)
+
+
+def resolve_static_test_dataset_path(path_template: str, log_root_path: str, robot: str) -> str:
+    """Resolve the preferred static test dataset path with compatibility fallbacks."""
+    primary_path = replace_test_dataset_tokens(path_template, log_root_path, robot)
+    filename = os.path.basename(primary_path)
+    flat_repo_path = os.path.join(get_test_dataset_root(log_root_path), filename)
+    legacy_ext_path = os.path.join(FDM_DATA_DIR, "Terrains", "test_datasets", filename)
+
+    for candidate in (primary_path, flat_repo_path, legacy_ext_path):
+        if os.path.isfile(candidate):
+            return candidate
+
+    return primary_path
+
+
+def get_eval_dataset_path(log_root_path: str, robot: str, terrain_name: str, suffix: str) -> str:
+    """Return the canonical path for a robot-scoped cached eval dataset."""
+    filename = f"{terrain_name}{suffix}_dataset.pkl"
+    return os.path.join(get_robot_test_dataset_dir(robot, log_root_path), filename)
+
+
+def resolve_eval_dataset_path(log_root_path: str, robot: str, terrain_name: str, suffix: str) -> str:
+    """Resolve a cached eval dataset path with compatibility fallback to the legacy flat layout."""
+    primary_path = get_eval_dataset_path(log_root_path, robot, terrain_name, suffix)
+    legacy_path = os.path.join(get_test_dataset_root(log_root_path), f"{terrain_name}{suffix}_dataset.pkl")
+
+    for candidate in (primary_path, legacy_path):
+        if os.path.isfile(candidate):
+            return candidate
+
+    return primary_path
diff --git a/home/cwl/fdm/scripts/inspect_config_cycle.py b/scripts/inspect_config_cycle.py
new file mode 100644
index 0000000..e7420cc
--- /dev/null
+++ b/scripts/inspect_config_cycle.py
@@ -0,0 +1,280 @@
+from __future__ import annotations
+
+import argparse
+import inspect
+import os
+import sys
+import traceback
+from collections.abc import Mapping, Sequence
+from types import SimpleNamespace
+
+
+def _is_scalar(obj: object) -> bool:
+    return obj is None or isinstance(obj, (bool, int, float, str, bytes))
+
+
+def _is_leaf_callable(obj: object) -> bool:
+    return inspect.isroutine(obj) or inspect.ismethod(obj) or inspect.isfunction(obj) or inspect.isbuiltin(obj)
+
+
+def _iter_children(obj: object):
+    if _is_scalar(obj):
+        return
+    if _is_leaf_callable(obj) or isinstance(obj, type) or inspect.ismodule(obj):
+        return
+
+    if isinstance(obj, Mapping):
+        for key, value in obj.items():
+            yield f"[{key!r}]", value
+        return
+
+    if isinstance(obj, (list, tuple)):
+        for index, value in enumerate(obj):
+            yield f"[{index}]", value
+        return
+
+    obj_dict = getattr(obj, "__dict__", None)
+    if obj_dict is None:
+        return
+
+    for key, value in obj_dict.items():
+        if key.startswith("__"):
+            continue
+        yield f".{key}", value
+
+
+def _find_cycle(root: object, root_name: str) -> tuple[str, str, str] | None:
+    active_paths: dict[int, str] = {}
+    visited: set[int] = set()
+
+    def _dfs(obj: object, path: str):
+        if _is_scalar(obj) or _is_leaf_callable(obj) or isinstance(obj, type) or inspect.ismodule(obj):
+            return None
+
+        obj_id = id(obj)
+        if obj_id in active_paths:
+            return active_paths[obj_id], path, type(obj).__name__
+        if obj_id in visited:
+            return None
+
+        visited.add(obj_id)
+        active_paths[obj_id] = path
+        for suffix, child in _iter_children(obj) or ():
+            result = _dfs(child, f"{path}{suffix}")
+            if result is not None:
+                return result
+        active_paths.pop(obj_id, None)
+        return None
+
+    return _dfs(root, root_name)
+
+
+def _collect_mutable_paths(root: object, root_name: str, limit: int = 20000) -> dict[int, list[str]]:
+    visited: set[int] = set()
+    paths: dict[int, list[str]] = {}
+
+    def _dfs(obj: object, path: str):
+        if len(visited) >= limit:
+            return
+        if _is_scalar(obj) or _is_leaf_callable(obj) or isinstance(obj, type) or inspect.ismodule(obj):
+            return
+
+        is_mutable_container = isinstance(obj, (Mapping, list, tuple)) or hasattr(obj, "__dict__")
+        if not is_mutable_container:
+            return
+
+        obj_id = id(obj)
+        if obj_id in visited:
+            paths.setdefault(obj_id, []).append(path)
+            return
+
+        visited.add(obj_id)
+        paths.setdefault(obj_id, []).append(path)
+        for suffix, child in _iter_children(obj) or ():
+            _dfs(child, f"{path}{suffix}")
+
+    _dfs(root, root_name)
+    return paths
+
+
+def _format_shared_objects(left_name: str, left_root: object, right_name: str, right_root: object) -> list[str]:
+    left_paths = _collect_mutable_paths(left_root, left_name)
+    right_paths = _collect_mutable_paths(right_root, right_name)
+    shared = []
+    for obj_id in sorted(set(left_paths).intersection(right_paths)):
+        left_path = left_paths[obj_id][0]
+        right_path = right_paths[obj_id][0]
+        if left_path == left_name and right_path == right_name:
+            continue
+        shared.append(f"id={obj_id} {left_path} <-> {right_path}")
+        if len(shared) >= 20:
+            break
+    return shared
+
+
+def _build_args(cli_args) -> SimpleNamespace:
+    return SimpleNamespace(
+        env=cli_args.env,
+        robot=cli_args.robot,
+        reduced_obs=cli_args.reduced_obs,
+        remove_torque=cli_args.remove_torque,
+        noise=cli_args.noise,
+        occlusions=cli_args.occlusions,
+        ablation_mode=cli_args.ablation_mode,
+        timestamp=cli_args.timestamp,
+        friction=cli_args.friction,
+        regular=cli_args.regular,
+        terrain_analysis_points=cli_args.terrain_analysis_points,
+        num_envs=cli_args.num_envs,
+        run_name=cli_args.run_name,
+        runs=["SOME_RUN"],
+        resume=None,
+    )
+
+
+def _load_cfg(args_cli):
+    if "omni.log" not in sys.modules:
+        try:
+            import omni.log  # noqa: F401
+        except ModuleNotFoundError:
+            import types
+
+            omni_module = sys.modules.setdefault("omni", types.ModuleType("omni"))
+            omni_log_module = types.ModuleType("omni.log")
+            omni_log_module.warn = lambda *args, **kwargs: None
+            omni_module.log = omni_log_module
+            sys.modules["omni.log"] = omni_log_module
+
+    from fdm.utils.args_cli_utils import (
+        ablation_studies_modifications,
+        cfg_modifier_pre_init,
+        robot_changes,
+        runner_cfg_init,
+    )
+
+    cfg = runner_cfg_init(args_cli)
+    cfg = robot_changes(cfg, args_cli)
+    cfg = cfg_modifier_pre_init(cfg, args_cli)
+    cfg = ablation_studies_modifications(cfg, args_cli)
+    return cfg
+
+
+def _log(fh, message: str):
+    fh.write(message + "\n")
+    fh.flush()
+
+
+def main():
+    parser = argparse.ArgumentParser(description="Inspect FDM config objects for cycles between sequential loads.")
+    parser.add_argument("--env", type=str, default="height", choices=["height", "depth"])
+    parser.add_argument("--robot", type=str, default="d5")
+    parser.add_argument("--num_envs", type=int, default=32)
+    parser.add_argument("--run_name", type=str, default="cycle_probe")
+    parser.add_argument("--log", type=str, default="config_cycle_report.txt")
+    parser.add_argument("--noise", action="store_true", default=False)
+    parser.add_argument("--occlusions", action="store_true", default=False)
+    parser.add_argument("--reduced_obs", action="store_true", default=True)
+    parser.add_argument("--remove_torque", action="store_true", default=True)
+    parser.add_argument("--friction", action="store_true", default=False)
+    parser.add_argument("--regular", action="store_true", default=False)
+    parser.add_argument("--ablation_mode", type=str, default=None)
+    parser.add_argument("--timestamp", type=float, default=None)
+    parser.add_argument("--terrain_analysis_points", type=int, default=None)
+    parser.add_argument("--launch_app", action="store_true", default=False)
+    parser.add_argument("--instantiate_first_runner", action="store_true", default=False)
+    parser.add_argument("--instantiate_second_runner", action="store_true", default=False)
+    cli_args = parser.parse_args()
+
+    if cli_args.instantiate_first_runner or cli_args.instantiate_second_runner:
+        cli_args.launch_app = True
+
+    os.makedirs(os.path.dirname(cli_args.log) or ".", exist_ok=True)
+
+    simulation_app = None
+    runner = None
+
+    with open(cli_args.log, "w", encoding="utf-8") as fh:
+        _log(fh, "START inspect_config_cycle")
+        _log(fh, f"args={vars(cli_args)}")
+        try:
+            if cli_args.launch_app:
+                from isaaclab.app import AppLauncher
+
+                _log(fh, "Launching AppLauncher(headless=True)...")
+                app_launcher = AppLauncher({"headless": True})
+                simulation_app = app_launcher.app
+
+            args_cli = _build_args(cli_args)
+
+            _log(fh, f"Building cfg1 ({args_cli.env})...")
+            cfg1 = _load_cfg(args_cli)
+            cycle1 = _find_cycle(cfg1.env_cfg, "cfg1.env_cfg")
+            _log(fh, f"cfg1 cycle={cycle1}")
+
+            if cli_args.instantiate_first_runner:
+                _log(fh, "Instantiating first runner...")
+                import omni
+                from fdm.runner import FDMRunner
+                from fdm.utils.args_cli_utils import env_modifier_post_init
+
+                runner = FDMRunner(cfg=cfg1, args_cli=args_cli, eval=False)
+                runner = env_modifier_post_init(runner, args_cli=args_cli)
+                _log(fh, "Closing first runner and resetting stage...")
+                runner.close()
+                runner = None
+                omni.usd.get_context().new_stage()
+
+            _log(fh, "Switching to baseline cfg2...")
+            args_cli.env = "baseline"
+            args_cli.runs = None
+            cfg2 = _load_cfg(args_cli)
+
+            cycle2 = _find_cycle(cfg2.env_cfg, "cfg2.env_cfg")
+            _log(fh, f"cfg2 cycle={cycle2}")
+
+            shared = _format_shared_objects("cfg1.env_cfg", cfg1.env_cfg, "cfg2.env_cfg", cfg2.env_cfg)
+            if shared:
+                _log(fh, "shared mutable objects between cfg1/cfg2:")
+                for item in shared:
+                    _log(fh, f"  {item}")
+            else:
+                _log(fh, "shared mutable objects between cfg1/cfg2: none detected")
+
+            if cli_args.instantiate_second_runner:
+                _log(fh, "Instantiating second runner...")
+                from fdm.runner import FDMRunner
+
+                runner = FDMRunner(cfg=cfg2, args_cli=args_cli, eval=True)
+                _log(fh, "Second runner setup: OK")
+                runner.close()
+                runner = None
+            else:
+                _log(fh, "Validating cfg2.env_cfg...")
+                try:
+                    cfg2.env_cfg.validate()
+                    _log(fh, "cfg2.env_cfg.validate(): OK")
+                except Exception as exc:  # noqa: BLE001
+                    _log(fh, f"cfg2.env_cfg.validate(): {type(exc).__name__}: {exc}")
+                    _log(fh, traceback.format_exc())
+
+        except Exception as exc:  # noqa: BLE001
+            _log(fh, f"UNHANDLED: {type(exc).__name__}: {exc}")
+            _log(fh, traceback.format_exc())
+        finally:
+            if runner is not None:
+                try:
+                    runner.close()
+                except Exception:  # noqa: BLE001
+                    _log(fh, "runner.close() failed during cleanup")
+                    _log(fh, traceback.format_exc())
+            if simulation_app is not None:
+                try:
+                    simulation_app.close()
+                except Exception:  # noqa: BLE001
+                    _log(fh, "simulation_app.close() failed during cleanup")
+                    _log(fh, traceback.format_exc())
+        _log(fh, "END inspect_config_cycle")
+
+
+if __name__ == "__main__":
+    main()
