+#!/usr/bin/env python3
+"""Automated checks for the height-map coordinate conventions.
+
+This script is intentionally simulator-free. It validates the transforms that are
+used across:
+
+1. nav_d5 -> FDM observation conversion
+2. FDM -> nav_d5 display alignment
+3. model / planner local-map index conventions
+
+If one of these conventions changes, the script exits non-zero.
+"""
+
+from __future__ import annotations
+
+import argparse
+import sys
+from dataclasses import dataclass
+from pathlib import Path
+
+import numpy as np
+
+
+@dataclass(frozen=True)
+class HeightMapCfg:
+    resolution: float = 0.05
+    shape_x: int = 100
+    shape_y: int = 100
+    scan_cut_x_min: float = -0.5
+    scan_cut_x_max: float = 1.0
+    scan_cut_y_min: float = -1.0
+    scan_cut_y_max: float = 1.0
+    sensor_offset_x: float = 0.0
+    sensor_offset_y: float = 0.0
+
+    @property
+    def scan_center_x(self) -> float:
+        return self.shape_x / 2
+
+    @property
+    def scan_center_y(self) -> float:
+        return 0.5 / self.resolution
+
+
+def nav_to_fdm(nav_height_map: np.ndarray) -> np.ndarray:
+    """Mirror of the conversion used in scripts/real_world_test.py."""
+    return np.flip(np.rot90(nav_height_map, 1), axis=0)
+
+
+def fdm_to_nav(fdm_height_map: np.ndarray) -> np.ndarray:
+    """Inverse of nav_to_fdm."""
+    return np.rot90(np.flip(fdm_height_map, axis=0), k=-1)
+
+
+def verify_display_alignment(fdm_height_map: np.ndarray) -> np.ndarray:
+    """Mirror of the visualization alignment used in scripts/verify_d5_robot_import.py."""
+    nav_aligned = np.rot90(np.flip(fdm_height_map, axis=0), k=-1)
+    return np.flip(nav_aligned, axis=0)
+
+
+def flatten_roundtrip_ok(nav_height_map: np.ndarray) -> tuple[bool, str]:
+    fdm_height_map = nav_to_fdm(nav_height_map)
+    recovered = fdm_to_nav(fdm_height_map)
+    if not np.array_equal(nav_height_map, recovered):
+        return False, "nav_to_fdm and fdm_to_nav are not inverse transforms"
+
+    aligned = verify_display_alignment(fdm_height_map)
+    if not np.array_equal(aligned, np.flip(nav_height_map, axis=0)):
+        return False, "verify display alignment does not match the documented convention"
+
+    return True, "round-trip transform checks passed"
+
+
+def model_center_index(state_xy: tuple[float, float], cfg: HeightMapCfg) -> tuple[int, int]:
+    """Index convention used by FDM height_scan_cut() for the robot center.
+
+    The code uses:
+        x_idx = -y / res + center_x
+        y_idx =  x / res + center_y
+    """
+
+    x, y = state_xy
+    idx_x = int(np.rint(-y / cfg.resolution + cfg.scan_center_x))
+    idx_y = int(np.rint(x / cfg.resolution + cfg.scan_center_y))
+    return idx_x, idx_y
+
+
+def planner_center_index(state_xy: tuple[float, float], cfg: HeightMapCfg) -> tuple[int, int]:
+    """Index convention used by planner cost_map_cost()."""
+
+    x, y = state_xy
+    grid_size_x = int(np.rint(cfg.shape_x))
+    grid_size_y = int(np.rint(cfg.shape_y))
+    idx_x = int(np.rint(grid_size_x / 2 - cfg.sensor_offset_y / cfg.resolution - y / cfg.resolution))
+    idx_y = int(np.rint(grid_size_y / 2 - cfg.sensor_offset_x / cfg.resolution + x / cfg.resolution))
+    return idx_x, idx_y
+
+
+def run_axis_checks(cfg: HeightMapCfg) -> list[str]:
+    msgs: list[str] = []
+    origin_model = model_center_index((0.0, 0.0), cfg)
+    origin_planner = planner_center_index((0.0, 0.0), cfg)
+
+    one_step = cfg.resolution
+    model_px = model_center_index((one_step, 0.0), cfg)
+    model_py = model_center_index((0.0, one_step), cfg)
+    planner_px = planner_center_index((one_step, 0.0), cfg)
+    planner_py = planner_center_index((0.0, one_step), cfg)
+
+    if (model_px[0] - origin_model[0], model_px[1] - origin_model[1]) != (0, 1):
+        raise AssertionError(
+            f"Model +x convention mismatch: expected (0, +1), got {(model_px[0] - origin_model[0], model_px[1] - origin_model[1])}"
+        )
+    if (model_py[0] - origin_model[0], model_py[1] - origin_model[1]) != (-1, 0):
+        raise AssertionError(
+            f"Model +y convention mismatch: expected (-1, 0), got {(model_py[0] - origin_model[0], model_py[1] - origin_model[1])}"
+        )
+    if (planner_px[0] - origin_planner[0], planner_px[1] - origin_planner[1]) != (0, 1):
+        raise AssertionError(
+            f"Planner +x convention mismatch: expected (0, +1), got {(planner_px[0] - origin_planner[0], planner_px[1] - origin_planner[1])}"
+        )
+    if (planner_py[0] - origin_planner[0], planner_py[1] - origin_planner[1]) != (-1, 0):
+        raise AssertionError(
+            f"Planner +y convention mismatch: expected (-1, 0), got {(planner_py[0] - origin_planner[0], planner_py[1] - origin_planner[1])}"
+        )
+
+    msgs.append(f"model origin index = {origin_model}, planner origin index = {origin_planner}")
+    msgs.append("model/planner axis conventions match for one-cell offsets")
+    return msgs
+
+
+def synthetic_height_map(shape_x: int, shape_y: int) -> np.ndarray:
+    """Generate a unique-valued map so flips/rotations are obvious."""
+    x_idx = np.arange(shape_x)[:, None]
+    y_idx = np.arange(shape_y)[None, :]
+    return x_idx * 1000 + y_idx
+
+
+def maybe_save_examples(save_dir: Path | None, nav_map: np.ndarray, fdm_map: np.ndarray, aligned: np.ndarray) -> None:
+    if save_dir is None:
+        return
+
+    save_dir.mkdir(parents=True, exist_ok=True)
+    try:
+        import matplotlib.pyplot as plt
+    except ImportError:
+        print("[WARN] matplotlib not installed, skipping image export.")
+        return
+
+    fig, axs = plt.subplots(1, 3, figsize=(12, 4))
+    axs[0].imshow(nav_map, cmap="viridis")
+    axs[0].set_title("nav input")
+    axs[1].imshow(fdm_map, cmap="viridis")
+    axs[1].set_title("FDM obs")
+    axs[2].imshow(aligned, cmap="viridis")
+    axs[2].set_title("verify alignment")
+    for ax in axs:
+        ax.axis("off")
+    fig.tight_layout()
+    fig.savefig(save_dir / "heightmap_transform_check.png", dpi=180)
+    plt.close(fig)
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser(description="Automated check for FDM/nav_d5 height-map transforms.")
+    parser.add_argument("--resolution", type=float, default=0.05, help="Height-map resolution in meters.")
+    parser.add_argument("--shape-x", type=int, default=100, help="Height-map size in x / row dimension.")
+    parser.add_argument("--shape-y", type=int, default=100, help="Height-map size in y / column dimension.")
+    parser.add_argument("--save-dir", type=str, default="", help="Optional directory to save example images.")
+    return parser.parse_args()
+
+
+def main() -> int:
+    args = parse_args()
+    cfg = HeightMapCfg(resolution=args.resolution, shape_x=args.shape_x, shape_y=args.shape_y)
+
+    nav_map = synthetic_height_map(cfg.shape_x, cfg.shape_y)
+    ok, message = flatten_roundtrip_ok(nav_map)
+    if not ok:
+        print(f"[FAIL] {message}")
+        return 1
+    print(f"[OK] {message}")
+
+    for msg in run_axis_checks(cfg):
+        print(f"[OK] {msg}")
+
+    fdm_map = nav_to_fdm(nav_map)
+    aligned = verify_display_alignment(fdm_map)
+    maybe_save_examples(Path(args.save_dir) if args.save_dir else None, nav_map, fdm_map, aligned)
+
+    print("[OK] all height-map transform checks passed")
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
